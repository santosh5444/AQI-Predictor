# ── AQI Backend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# Port (Render sets this automatically — do not hardcode)
PORT=3001

# Comma-separated list of allowed frontend origins
# Add your deployed frontend URL here after deploying
# Example: ALLOWED_ORIGINS=https://your-app.onrender.com,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
